{
  "name": "loom-runtime",
  "version": "1.0.0",
  "description": "Brand communications runtime",
  "type": "module",
  "bin": {
    "loom": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "cli": "tsx src/cli.ts",
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/cli.js --packages=external && node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\"",
    "check": "vitest run && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1017.0",
    "@google/genai": "^0.14.0",
    "@resvg/resvg-js": "^2.6.2",
    "canvas": "^3.2.1",
    "dotenv": "^16.4.7",
    "js-yaml": "^4.1.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.18.12",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.17"
  }
}
